<xml xmlns="https://developers.google.com/blockly/xml"><block type="pxt-on-start" id="`xSkYCT#ew@|8AtKrR@[" x="0" y="0"><statement name="HANDLER"><block type="typescript_statement" id="`HjcK.02U9l4|oCdrQQX" editable="false"><mutation xmlns="http://www.w3.org/1999/xhtml" line0="enum EYES {" line1="    //% block=&quot;Open&quot;" line2="    OPEN," line3="    //% block=&quot;Sad&quot;" line4="    SAD," line5="    //% block=&quot;Shut&quot;" line6="    SHUT," line7="    //% block=&quot;Mad&quot;" line8="    MAD," line9="    //% block=&quot;Up&quot;" line10="    UP," line11="    //% block=&quot;Pop&quot;" line12="    POP," line13="    //% block=&quot;Left&quot;" line14="    LEFT," line15="    //% block=&quot;Right&quot;" line16="    RIGHT," line17="    //% block=&quot;Wink&quot;" line18="    WINK," line19="    //% block=&quot;Flip&quot;" line20="    FLIP" line21="}" numlines="22"></mutation><next><block type="typescript_statement" id="!/NeLLs0oFGKI;#313(D" editable="false"><mutation xmlns="http://www.w3.org/1999/xhtml" line0="enum MOUTHS {" line1="    //% block=&quot;Flat&quot;" line2="    FLAT," line3="    //% block=&quot;OK&quot;" line4="    OK," line5="    //% block=&quot;Grin&quot;" line6="    GRIN," line7="    //% block=&quot;Sulk&quot;" line8="    SULK," line9="    //% block=&quot;Hmmm&quot;" line10="    HMMM," line11="    //% block=&quot;Open&quot;" line12="    OPEN," line13="    //% block=&quot;Left&quot;" line14="    LEFT," line15="    //% block=&quot;Right&quot;" line16="    RIGHT," line17="    //% block=&quot;Shout&quot;" line18="    SHOUT," line19="    //% block=&quot;Laugh&quot;" line20="    LAUGH," line21="    //% block=&quot;Smirk&quot;" line22="    SMIRK," line23="    //% block=&quot;Kiss&quot;" line24="    KISS," line25="    //% block=&quot;Flip&quot;" line26="    FLIP" line27="}" numlines="28"></mutation><next><block type="typescript_statement" id="Bo{@]myvx@FRfmJROx(t" editable="false"><mutation xmlns="http://www.w3.org/1999/xhtml" line0="enum MOODS {" line1="    //% block=&quot;None&quot;" line2="    NONE," line3="    //% block=&quot;Happy&quot;" line4="    HAPPY," line5="    //% block=&quot;Sad&quot;" line6="    SAD," line7="    //% block=&quot;Angry&quot;" line8="    ANGRY," line9="    //% block=&quot;Surprised&quot;" line10="    SURPRISED," line11="    //% block=&quot;Asleep&quot;" line12="    ASLEEP," line13="    //% block=&quot;Snoring&quot;" line14="    SNORING," line15="    //% block=&quot;Shiver&quot;" line16="    SHIVER," line17="    //% block=&quot;Tickle&quot;" line18="    TICKLE," line19="    //% block=&quot;Dead&quot;" line20="    DEAD" line21="}" numlines="22"></mutation><next><block type="typescript_statement" id="~L`C!E@1CT6acoiIuZOo" editable="false"><mutation xmlns="http://www.w3.org/1999/xhtml" line0="namespace Emote {" line1="" line2="    // ensure these constants match the enum ordering!" line3="    const all_eyes = [" line4="        891,  //&quot;Open&quot;" line5="        874,  //&quot;Sad&quot;" line6="        864,  //&quot;Shut&quot;" line7="        347,  //&quot;Mad&quot;" line8="        27,   //&quot;Up&quot;" line9="        561,  //&quot;Pop&quot;" line10="        873,  //&quot;Left&quot;" line11="        882,  //&quot;Right&quot;" line12="        867,  //&quot;Wink&quot;" line13="        324   //&quot;Flip&quot;" line14="    ]" line15="" line16="    const all_mouths = [" line17="        448,    //&quot;Flat&quot;" line18="        4416,   //&quot;OK&quot;" line19="        14880,  //&quot;Grin&quot;" line20="        17856,  //&quot;Sulk&quot;" line21="        14464,  //&quot;Hmmm&quot;" line22="        4420,   //&quot;Open&quot;" line23="        6240,   //&quot;Left&quot;" line24="        13056,  //&quot;Right&quot;" line25="        14660,  //&quot;Shout&quot;" line26="        15204,  //&quot;Laugh&quot;" line27="        6944,   //&quot;Smirk&quot;" line28="        128,    //&quot;Kiss&quot;" line29="        28512   //&quot;Flip&quot;" line30="    ]" line31="" line32="    let main_eyes = 0" line33="    let main_mouth = 0" line34="    let alt_eyes = 0" line35="    let alt_mouth = 0" line36="    let switching = false" line37="    let switch_gap = 0;" line38="    let switch_time = 0" line39="    let switch_vary = 0" line40="" line41="    //% block=&quot;show eyes as $eyes&quot;" line42="    //% weight=20" line43="    export function show_eyes(eyes: EYES) {" line44="        switching = false" line45="        show_bitmap(all_eyes[eyes], 0, 2)" line46="    }" line47="" line48="    //% block=&quot;show mouth as $mouth&quot;" line49="    //% weight=10" line50="    export function show_mouth(mouth: MOUTHS) {" line51="        switching = false" line52="        show_bitmap(all_mouths[mouth], 2, 5)" line53="    }" line54="" line55="    //% block=&quot;show face with eyes= $eyes, mouth= $mouth&quot;" line56="    //% weight=30" line57="    export function emote(eyes: EYES, mouth: MOUTHS) {" line58="        switching = false" line59="        show_bitmap(all_eyes[eyes], 0, 2)" line60="        show_bitmap(all_mouths[mouth], 2, 5)" line61="    }" line62="" line63="    //% block=&quot;react as $mood&quot;" line64="    //% weight=50" line65="    export function new_mood(mood: MOODS) {" line66="        // constrain to currently defined values" line67="        if (mood == MOODS.SNORING) {" line68="            set_mood(EYES.SHUT, MOUTHS.FLAT, EYES.SHUT, MOUTHS.OPEN, 2000, 2000, 0)" line69="        } else if (mood == MOODS.ASLEEP) {" line70="            set_mood(EYES.SHUT, MOUTHS.FLAT, EYES.SHUT, MOUTHS.HMMM, 3000, 500, 0)" line71="        } else if (mood == MOODS.NONE) {" line72="            set_mood(EYES.OPEN, MOUTHS.FLAT, EYES.SHUT, MOUTHS.FLAT, 600, 300, 2)" line73="        } else if (mood == MOODS.HAPPY) {" line74="            set_mood(EYES.OPEN, MOUTHS.GRIN, EYES.WINK, MOUTHS.SMIRK, 1500, 400, 2)" line75="        } else if (mood == MOODS.SAD) {" line76="            set_mood(EYES.SAD, MOUTHS.SULK, EYES.SHUT, MOUTHS.SULK, 4000, 600, 1)" line77="        } else if (mood == MOODS.ANGRY) {" line78="            set_mood(EYES.MAD, MOUTHS.HMMM, EYES.MAD, MOUTHS.SHOUT, 2000, 800, 1)" line79="        } else if (mood == MOODS.SURPRISED) {" line80="            set_mood(EYES.POP, MOUTHS.OPEN, EYES.OPEN, MOUTHS.OPEN, 1600, 400, 0)" line81="        } else if (mood == MOODS.SHIVER) {" line82="            set_mood(EYES.LEFT, MOUTHS.RIGHT, EYES.RIGHT, MOUTHS.LEFT, 150, 150, 0)" line83="        } else if (mood == MOODS.TICKLE) {" line84="            set_mood(EYES.OPEN, MOUTHS.OK, EYES.FLIP, MOUTHS.FLIP, 750, 250, 0)" line85="        }" line86="        if (mood == MOODS.DEAD) {" line87="            basic.showIcon(IconNames.Skull)" line88="        }" line89="    }" line90="" line91="    //% block=&quot;stop reacting&quot;" line92="    //% weight=40" line93="    export function cease() {" line94="        switching = false" line95="    }" line96="" line97="    function set_mood(eyes: EYES, mouth: MOUTHS, other_eyes: EYES, other_mouth: MOUTHS, gap: number, time: number, vary: number) {" line98="        switching = false" line99="        main_eyes = eyes" line100="        main_mouth = mouth" line101="        alt_eyes = other_eyes" line102="        alt_mouth = other_mouth" line103="        /*" line104="        In most moods, we sporadically switch between two faces." line105="        So we may be blinking, snoring, shivering or laughing etc." line106="        These are controlled by two time-periods: &quot;switch_gap&quot; governs how often, " line107="            and &quot;switch_time&quot; says how long, --to show the alternate Face2." line108="        A non-zero &quot;switch_vary&quot; allows for extension of the gap" line109="            by an unpredictable multiple." line110="        */" line111="        switch_gap = gap" line112="        switch_time = time" line113="        switch_vary = vary" line114="        switching = true" line115="        show_bitmap(all_eyes[main_eyes], 0, 2)" line116="        show_bitmap(all_mouths[main_mouth], 2, 5)" line117="        control.inBackground(function () {" line118="            while (switching) {" line119="                show_bitmap(all_eyes[alt_eyes], 0, 2)" line120="                show_bitmap(all_mouths[alt_mouth], 2, 5)" line121="                pause(switch_time)" line122="                show_bitmap(all_eyes[main_eyes], 0, 2)" line123="                show_bitmap(all_mouths[main_mouth], 2, 5)" line124="                pause(switch_gap + randint(0, switch_vary) * switch_gap)" line125="            }" line126="        })" line127="    }" line128="    " line129="    function show_bitmap(bitmap: number, start: number, stop: NumberFormat) {" line130="        for (let y = start; y &lt; stop; y++) {" line131="            for (let x = 0; x &lt; 5; x++) {" line132="                if (bitmap &amp; 1) {" line133="                    led.plot(x, y)" line134="                } else {" line135="                    led.unplot(x, y)" line136="                }" line137="                bitmap &gt;&gt;= 1" line138="            }" line139="        }" line140="    }" line141="}" numlines="142"></mutation></block></next></block></next></block></next></block></statement></block></xml>